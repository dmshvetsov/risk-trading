{
  "name": "rfq-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec wrangler dev",
    "test": "pnpm exec vitest run",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "db:migrate": "pnpm exec wrangler d1 migrations apply DB",
    "db:migrate:staging": "pnpm exec wrangler d1 migrations apply DB --env staging",
    "deploy:staging": "pnpm exec wrangler deploy --env staging"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "^4.0.15",
    "wrangler": "4.98.0"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.2",
    "hono": "^4.12.23",
    "zod": "^4.4.3"
  }
}
